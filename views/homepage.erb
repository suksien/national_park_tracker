<% if @parks.size <= 1 %>
  <p>There is <%= @parks.size %> national park in your tracker! </p>
<% else %>
  <p>There are <%= @parks.size %> national parks in your tracker! </p>
<% end %>

<p><a href="/add-park">Add a park</a></p>

<p><a href="/visited">Visited</a> | <a href="/not-yet-visited">Not visited</a> | 
   <a href="/parks-by-state">By state</a> | <a href="/parks-by-year">By year</a> | 
   <a href="/parks-by-area">By area</a>
</p>

<div>
  <table>
    <tr>
      <th>No</th>
      <th>Name</th>
      <th>State</th>
      <th>Date established</th>
      <th>Area (km2)</th>
      <th>Visited</th>
    </tr>
    <% sort_parks(@parks, "id").each_with_index do |park, index| %>
      <tr>
        <td><%= index + 1 %></td>
        <td><a href="/<%= park[:name] %>/"><%= park[:name] %></a>
            <form class="delete" method="post" action="/<%= park[:name] %>/delete">
              <input type="image" width=15 height=15 src="/images/icon_delete.png">
            </form>
        </td>
        <td><%= park[:state] %></td>
        <td><%= park[:date_established] %></td>
        <td><%= park[:area_km2] %></td>
        <td><%= park[:visited]? "Yes" : "No" %></td>
      </tr>
    <% end %>
  </table>
</div>

