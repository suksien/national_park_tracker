<p><a href="/visited">Visited</a> <a href="/not-yet-visited">Not visited</a>
</p>

<p><a href="/parks-by-state">By state</a> <a href="/parks-by-year">By year</a> <a href="/parks-by-area">By area</a>
</p>

<div>
  <table>
    <tr>
      <th>Name</th>
      <th>State</th>
      <th>Date established</th>
      <th>Area (km2)</th>
      <th>Visited</th>
    </tr>
    <% sort_parks(@parks, @criteria).each do |park| %>
      <tr>
        <td><a href="/<%= park[:name] %>/"><%= park[:name] %></a></td>
        <td><%= park[:state] %></td>
        <td><%= park[:date_established] %></td>
        <td><%= park[:area_km2] %></td>
        <td><%= park[:visited]? "Yes" : "No" %></td>
      </tr>
    <% end %>
  </table>
</div>

<p>There are <%= @parks.size %> national parks in your tracker! </p>
<p><a href="/add-park">Add a park</a></p>

