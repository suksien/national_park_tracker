<br>
<div>
  <table>
    <tr>
      <th>Name</th>
      <th>State</th>
      <th>Date established</th>
      <th>Area (km2)</th>
    </tr>
    <% @parks.each do |park| %>
      <tr>
        <td><a href="/<%= park[:name] %>/"><%= park[:name] %></a></td>
        <td><%= park[:state] %></td>
        <td><%= park[:date_established] %></td>
        <td><%= park[:area_km2] %></td>
      </tr>
    <% end %>
  </table>
</div>

