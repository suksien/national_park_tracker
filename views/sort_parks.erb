<h2>Parks sorted by <%= @criteria.to_s %></h2>

<br>
<div>
  <table>
    <tr>
      <th>No</th>
      <th>Name</th>
      <th>State</th>
      <th>Date established</th>
      <th>Area (km2)</th>
      <th>Visited</th>
    </tr>
    <% sort_parks(@parks, @criteria).each_with_index do |park, index| %>
      <tr>
        <td><%= index + 1 %></td>
        <td><a href="/<%= park[:name] %>/"><%= park[:name] %></a></td>
        <td><%= park[:state] %></td>
        <td><%= park[:date_established] %></td>
        <td><%= park[:area_km2] %></td>
        <td><%= park[:visited]? "Yes" : "No" %></td>
      </tr>
    <% end %>
  </table>
</div>

<br>
<a href="/">Back to homepage</a>