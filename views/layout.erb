<!doctype html>
<html lang="en-US">
  <head>
    <title>National Park Tracker</title>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/stylesheets/app.css">
  </head>
  <header>
    <h1>National Park Tracker
    </h1>
  </header>
  <body>
    <% if session[:error] %>
      <div class="error">
        <%= session.delete(:error) %>
      </div>
    <% end %>

    <% if session[:message] %>
      <div class="message">
        <%= session.delete(:message) %>
      </div>
    <% end %>
  </body>
  <main>
    <p><%== yield_content :homepage_link %></p>
    <%== yield %>
  </main>

</html>
